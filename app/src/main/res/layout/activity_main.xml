<?xml version="1.0" encoding="utf-8"?>
<!--
    FrameLayout root: lets tvCountdown overlay sit on top of the game UI
    without affecting the layout structure below it.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <!-- ── Main game UI ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ════════════════════════════════════════════════════════════
             HEADER
             fitsSystemWindows pushes content below the status bar so
             "Re:Pattern" never overlaps the clock or camera cutout.
             High score lives here (right-aligned) so it never affects
             the content flow below.
        ════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bg_header"
            android:fitsSystemWindows="true"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:paddingEnd="24dp"
            android:gravity="center_vertical">

            <!-- App name — explicit marginStart so fitsSystemWindows cannot override it -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="32dp"
                android:text="Re:Pattern"
                android:textSize="28sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

        </LinearLayout>

        <!-- High score — directly below header, right-aligned -->
        <TextView
            android:id="@+id/tvHighScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="High Score: 0"
            android:textSize="17sp"
            android:textColor="@color/tile_correct"
            android:textStyle="bold"
            android:gravity="end"
            android:paddingEnd="24dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <!-- ════════════════════════════════════════════════════════════
             CONTENT AREA
             Fills all remaining height below the header.
             Divided into three fixed zones so the grid never shifts:
               1. Info block  (wrap_content, centered vertically via weight)
               2. Grid block  (wrap_content, centered)
               3. Button zone (fixed 88dp — always reserves space)
        ════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- ── Spacer above info block: weight 1 — pulls content upward ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- ── INFO BLOCK ─────────────────────────────────────── -->
            <!-- Level, status, and timer are grouped here.            -->
            <!-- This block is wrap_content so it never pushes the     -->
            <!-- grid — the spacers absorb all extra space.            -->

            <!-- Level number -->
            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Level 1"
                android:textSize="48sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Status message -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Press Start to Begin!"
                android:textSize="20sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="6dp" />

            <!--
                Timer — always occupies its line height via a non-empty
                placeholder (" ") so the info block height never changes
                and the grid never shifts when the timer text appears.
            -->
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" "
                android:textSize="34sp"
                android:textColor="@color/tile_highlight"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="6dp" />

            <!-- ── GRID ───────────────────────────────────────────── -->
            <!--
                Grid position is controlled by the weight spacers above and
                below. The fixed-height button zone beneath means the grid
                never shifts when the button appears or disappears.
            -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View android:id="@+id/tile0" style="@style/TileButton" />
                    <View android:id="@+id/tile1" style="@style/TileButton" />
                    <View android:id="@+id/tile2" style="@style/TileButton" />
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View android:id="@+id/tile3" style="@style/TileButton" />
                    <View android:id="@+id/tile4" style="@style/TileButton" />
                    <View android:id="@+id/tile5" style="@style/TileButton" />
                </LinearLayout>

                <!-- Row 3 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View android:id="@+id/tile6" style="@style/TileButton" />
                    <View android:id="@+id/tile7" style="@style/TileButton" />
                    <View android:id="@+id/tile8" style="@style/TileButton" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── Spacer between grid and button zone ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- ════════════════════════════════════════════════════
                 BUTTON ZONE — fixed 72dp height, always present.
                 The button uses VISIBLE/GONE but the zone itself
                 never changes size, so the grid above never moves.
            ════════════════════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="220dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:text="Start Game"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:background="@drawable/btn_start_background"
                    android:stateListAnimator="@null"
                    android:visibility="visible" />

            </FrameLayout>

            <!-- ── Final bottom spacer: weight 2 — absorbs extra space at bottom ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="2" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── READY / countdown overlay ────────────────────────────────────── -->
    <!--
        Full-screen overlay for the READY/3/2/1 countdown.
        GONE by default — made VISIBLE only during the countdown coroutine.
    -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text=""
        android:textSize="80sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#CC1A1A2E"
        android:visibility="gone" />

</FrameLayout>
